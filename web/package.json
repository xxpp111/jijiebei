{
  "name": "jjb-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "e2e:ui": "npm run build --silent && node e2e/ui-smoke.mjs",
    "e2e:r6": "npm run build --silent && node e2e/r6-doubles-downstream.mjs",
    "preview": "vite preview --port 7788",
    "test:unit": "vitest run",
    "test:drift": "node scripts/drift-check.mjs",
    "test:back": "cd ../backend && go test ./...",
    "test": "npm run test:unit && npm run test:drift && npm run test:back"
  },
  "dependencies": {
    "@zumer/snapdom": "^2.12.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
